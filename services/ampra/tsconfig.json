// tsconfig.json
{
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "baseUrl": "./",
    "paths": {
      "*": ["./*"]
    }
  },
  "ts-node": {
    "experimentalSpecifierResolution": "node",
    "transpileOnly": true,
    "esm": true,
    "moduleResolution": "node",
    "compilerOptions": {
      "module": "commonjs",
      "moduleResolution": "node"
    }
  }
}
